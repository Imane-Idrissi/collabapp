# Required in production
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Database (use DATABASE_URL or individual vars)
DATABASE_URL=postgres://user:pass@host:5432/collabapp

# Optional — defaults to False
DEBUG=False

# Redis (required for WebSocket in multi-instance deploys)
REDIS_URL=redis://localhost:6379

# Email (Resend) — required for verification + password reset
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# File storage (S3) — without this, uploads use local filesystem
AWS_STORAGE_BUCKET_NAME=your-bucket
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# AI task extraction — optional, users can also set per-project keys
GEMINI_API_KEY=
